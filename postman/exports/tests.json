        {
          "name": "POST New Timezone",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "//TEST 1",
                  "//main create test status",
                  "pm.test(\"Status code is 201 (Created)\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "//TEST 2",
                  "//test created ID",
                  "//responseBody is requestBody",
                  "//24 is length of mongo IDs",
                  "pm.test(\"Response has created an ID\", function() {",
                  "    const responseBody = pm.response.json();",
                  "    pm.expect(responseBody.data).to.have.property(\"_id\").that.is.not.null;",
                  "    pm.expect(responseBody.data._id).to.have.lengthOf(24);",
                  "    //this makes the test automation run ... std key value pairing",
                  "    pm.collectionVariables.set(\"timezoneID\", responseBody.data._id);",
                  "});",
                  "//TEST 3",
                  "pm.test(\"The response has all properties\", () => {",
                  "    //parse the response JSON and test 3 properties",
                  "    const responseBody = pm.response.json();",
                  "    const { data } = responseBody;",
                  "    pm.expect(data.name).to.be.a('string');",
                  "    pm.expect(data.fullName).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],

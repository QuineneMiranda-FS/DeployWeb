                  "pm.test(\"Response has the correct ID\", function () {",
                  "    const jsonData = pm.response.json();",
                  "  //  console.log(jsonData); //show exact structure where id is",
                  "    pm.expect(jsonData.data._id).to.eql(\"69b8a9682ee74e2a0daf2a6f\");",
                  "});",
                  "//TEST 3",
                  "//check other fields of id requested",
                  "pm.test(\"Response body has required fields\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('name');",
